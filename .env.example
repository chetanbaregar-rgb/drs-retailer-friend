# ── Required ──────────────────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets webhook (leads go here instantly) ───────────────────────────
GAS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbxv5peVw4dYTRdcIRCwxjsf_-ck2ACa7nE3_Mfmy44xenBz8wqaaN0V4Ow9zoyhpiPY/exec

# ── Lead notifications (email on every signup) ─────────────────────────────────
# The inbox that receives "New lead" emails
NOTIFY_EMAIL=you@retearn.ai

# SMTP credentials — Gmail example below (use an App Password, not your main password)
# For Gmail: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# SendGrid example (uncomment and replace above if using SendGrid):
